# SMTP settings for the contact form (used server-side by /api/contact).
# These are NOT VITE_-prefixed: they stay on the server and are never shipped
# to the browser. Set them in Vercel: Project -> Settings -> Environment
# Variables (Production + Preview + Development), then redeploy.
#
# Gmail example (requires 2FA on the Google account + an App Password):
#   1. Google Account -> Security -> 2-Step Verification (must be ON).
#   2. Security -> App passwords -> generate one for "Mail". Use that 16-char
#      value as SMTP_PASS (remove the spaces).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=hi.andrewbayu@gmail.com
SMTP_PASS=your-16-char-app-password
# Where inquiries are delivered. Defaults to SMTP_USER if omitted.
CONTACT_TO=hi.andrewbayu@gmail.com

# ── Resend setup (custom-domain sending; preferred over Gmail) ────────────────
# Verify adityabayu.com in Resend, add its DNS records in Vercel (DNS host), then:
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=465
#   SMTP_USER=resend                 # literal string, not an email
#   SMTP_PASS=re_xxxxxxxxxxxx         # Resend API key
#   CONTACT_TO=hi.andrewbayu@gmail.com
#   MAIL_FROM=Aditya Bayu <hi@adityabayu.com>   # must be on the verified domain
# MAIL_FROM overrides the From header; required for Resend (SMTP_USER is "resend").
#
# Marketing list: /api/contact also adds every submitter to the Resend Audience
# (POST https://api.resend.com/contacts — single default audience, no id needed).
# Runs automatically whenever the Resend key (SMTP_PASS, re_*) is set. Optional
# override if you want a separate key from the SMTP one:
#   RESEND_API_KEY=re_xxxxxxxx   # defaults to SMTP_PASS

# ─────────────────────────────────────────────────────────────────────────────
# learn.adityabayu.com — paid course (Xendit + Supabase)
# ─────────────────────────────────────────────────────────────────────────────

# Xendit (server-only). Dashboard -> Settings -> API Keys (use TEST keys first).
# Callback token: Settings -> Callbacks/Webhooks; set webhook URL to
#   https://learn.adityabayu.com/api/xendit-webhook
XENDIT_SECRET_KEY=xnd_development_xxxxxxxxxxxxxxxx
XENDIT_CALLBACK_TOKEN=your-xendit-callback-verification-token

# Course price in IDR (integer, no decimals). e.g. 299000 = Rp299.000
COURSE_PRICE_IDR=299000

# Supabase server-only (service role bypasses RLS — NEVER expose to the browser).
# Dashboard -> Project Settings -> API.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service-role...

# Supabase client (VITE_ prefix = shipped to the browser; anon key is safe to expose).
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...anon...

# Price shown on the paywall button (display only; charged amount is COURSE_PRICE_IDR).
VITE_COURSE_PRICE_LABEL=Rp299.000
